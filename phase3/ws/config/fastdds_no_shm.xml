<?xml version="1.0" encoding="UTF-8" ?>
<!--
  FastDDS 共有メモリ無効化プロファイル

  問題: ipc: host 設定でコンテナがホストの /dev/shm を共有するため、
        前回のコンテナ起動で残った fastrtps_port* ファイルが 0 バイトのまま
        残存し、新しいノード (特に map_server) が DDS 初期化でブロックされる。

  解決: 共有メモリトランスポートを無効にし UDPv4 のみ使用する。
        同一ホスト内の通信は UDP ループバック経由になり性能は若干低下するが、
        学習環境では問題ない。
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <transport_descriptors>
    <transport_descriptor>
      <transport_id>udpv4_transport</transport_id>
      <type>UDPv4</type>
    </transport_descriptor>
  </transport_descriptors>

  <participant profile_name="default_participant" is_default_profile="true">
    <rtps>
      <!-- 組み込みトランスポート (共有メモリ含む) を無効にして UDPv4 のみ使用 -->
      <useBuiltinTransports>false</useBuiltinTransports>
      <userTransports>
        <transport_id>udpv4_transport</transport_id>
      </userTransports>
    </rtps>
  </participant>
</profiles>
